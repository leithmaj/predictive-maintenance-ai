# Base image — slim Python 3.11, minimal size
FROM python:3.11-slim

# Set working directory inside the container
WORKDIR /app

# Copy requirements first — Docker caches this layer
# If only your code changes, Docker won't reinstall dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code and model files
COPY main.py .
COPY model.pkl .
COPY label_encoder.pkl .

# Expose port 8000
EXPOSE 8000

# Command to run when container starts.

# By default uvicorn listens on 127.0.0.1 — only accessible from inside the container. 
# 0.0.0.0 tells it to accept connections from outside the container, which is required 
# for Docker port mapping to work.
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"] 